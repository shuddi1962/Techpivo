# ── RSS Feed ──────────────────────────────────────────────────────────────
RSS_URL=https://techpivo.com/rss.xml
POLL_INTERVAL_MINUTES=15
CRON_SCHEDULE=*/15 * * * *

# ── Platform toggles (set to true to enable) ──────────────────────────────
ENABLE_FACEBOOK=false
ENABLE_INSTAGRAM=false
ENABLE_THREADS=false
ENABLE_LINKEDIN=false
ENABLE_X=false
ENABLE_TELEGRAM=false
ENABLE_REDDIT=false
ENABLE_WHATSAPP=false
ENABLE_MEDIUM=false
ENABLE_DEVTO=false
ENABLE_HASHNODE=false
ENABLE_PINTEREST=false
ENABLE_YOUTUBE_COMMUNITY=false

# ── Facebook Page ─────────────────────────────────────────────────────────
# Guide: developers.facebook.com → create Business app → add Pages API
# Get Page ID from your Page's "About" section
FB_PAGE_ID=
# Generate via Graph API Explorer → pages_manage_posts permission
FB_PAGE_ACCESS_TOKEN=

# ── Instagram Business (linked to same Facebook Page) ─────────────────────
# Link Instagram Business account to your FB Page in Meta Business Suite
IG_USER_ID=

# ── Threads (separate OAuth from Facebook) ────────────────────────────────
# Add "Threads API" product to your Meta app, run Threads-specific OAuth
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── LinkedIn Company Page ─────────────────────────────────────────────────
# dev: developer.linkedin.com → create app → request w_organization_social
# ORG URN format: urn:li:organization:<numeric_id>
LINKEDIN_ORG_URN=
LINKEDIN_ACCESS_TOKEN=

# ── X / Twitter (OAuth 1.0a) ─────────────────────────────────────────────
# Requires at least Basic paid tier on developer.x.com for write access
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Telegram Channel ──────────────────────────────────────────────────────
# Create bot via @BotFather → add bot as admin to your channel
# Chat ID: send message in channel → https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Reddit ────────────────────────────────────────────────────────────────
# Create script app at reddit.com/prefs/apps → generate refresh token
# Default subreddit is "technology" — override here
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_SUBREDDIT=technology

# ── WhatsApp Channel ──────────────────────────────────────────────────────
# FB Developer → Create Business app → WhatsApp → get Phone Number ID + token
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Medium ────────────────────────────────────────────────────────────────
# medium.com/me/settings/security → Integration Tokens → Get token
MEDIUM_INTEGRATION_TOKEN=

# ── Dev.to ────────────────────────────────────────────────────────────────
# dev.to/settings/account → API Key section → Generate
DEVTO_API_KEY=

# ── Hashnode ──────────────────────────────────────────────────────────────
# hashnode.com/settings/developer → Personal Access Token → Generate
HASHNODE_PAT=

# ── Pinterest ─────────────────────────────────────────────────────────────
# developers.pinterest.com → create app → submit for review → get token
# Optional: set a board ID to pin to a specific board
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# ── YouTube Community ─────────────────────────────────────────────────────
# Requires OAuth 2.0 access token (API key not sufficient for Community posts)
# Google Cloud Console → enable YouTube Data API v3 → OAuth consent
YOUTUBE_CHANNEL_ID=
YOUTUBE_API_KEY=
YOUTUBE_ACCESS_TOKEN=

# ── Custom message templates (optional) ───────────────────────────────────
# Available variables: {title}, {url}, {excerpt}, {tags}
# FACEBOOK_TEMPLATE={title}\n\n{excerpt}\n\n{url}
# INSTAGRAM_TEMPLATE={title}\n\n{excerpt}\n\nLink in bio 🔗\ntechpivo.com
# THREADS_TEMPLATE={title}\n\n{excerpt}\n\n{url}
# LINKEDIN_TEMPLATE={title}\n\n{excerpt}\n\n{url}
# X_TEMPLATE={title}\n\n{url}
# TELEGRAM_TEMPLATE=<b>{title}</b>\n\n{excerpt}\n\n{url}
# WHATSAPP_TEMPLATE={title}\n\n{excerpt}\n\n{url}
# PINTEREST_TEMPLATE={title}\n\n{excerpt}\n\n{url}
# YOUTUBE_TEMPLATE={title}\n\n{excerpt}\n\n{url}
