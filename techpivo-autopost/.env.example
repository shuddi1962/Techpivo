# ── RSS Feed ──────────────────────────────────────────────────────────────
RSS_FEED_URL=https://techpivo.com/rss.xml
CRON_SCHEDULE=*/15 * * * *

# ── Platform toggles (set to true to enable) ──────────────────────────────
ENABLE_FACEBOOK=false
ENABLE_INSTAGRAM=false
ENABLE_THREADS=false
ENABLE_LINKEDIN=false
ENABLE_X=false
ENABLE_TELEGRAM=false
ENABLE_REDDIT=false
ENABLE_WHATSAPP=false
ENABLE_MEDIUM=false
ENABLE_DEVTO=false
ENABLE_HASHNODE=false
ENABLE_PINTEREST=false
ENABLE_YOUTUBE_COMMUNITY=false

# ── Facebook Page ─────────────────────────────────────────────────────────
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=

# ── Instagram Business ────────────────────────────────────────────────────
IG_USER_ID=

# ── Threads ───────────────────────────────────────────────────────────────
THREADS_USER_ID=
THREADS_ACCESS_TOKEN=

# ── LinkedIn Company Page ─────────────────────────────────────────────────
LINKEDIN_ORG_URN=urn:li:organization:<numeric_id>
LINKEDIN_ACCESS_TOKEN=

# ── X / Twitter ───────────────────────────────────────────────────────────
X_APP_KEY=
X_APP_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# ── Telegram Channel ──────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ── Reddit ────────────────────────────────────────────────────────────────
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_REFRESH_TOKEN=
REDDIT_SUBREDDIT=technology

# ── WhatsApp Channel ──────────────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Medium ────────────────────────────────────────────────────────────────
MEDIUM_INTEGRATION_TOKEN=

# ── Dev.to ────────────────────────────────────────────────────────────────
DEVTO_API_KEY=

# ── Hashnode ──────────────────────────────────────────────────────────────
HASHNODE_PAT=

# ── Pinterest ─────────────────────────────────────────────────────────────
PINTEREST_ACCESS_TOKEN=
PINTEREST_BOARD_ID=

# ── YouTube Community ─────────────────────────────────────────────────────
YOUTUBE_CHANNEL_ID=
YOUTUBE_ACCESS_TOKEN=

# ── Graph API version (used by Facebook, Instagram, Threads) ─────────────
GRAPH_API_VERSION=v21.0

# ── Custom message templates (optional) ───────────────────────────────────
# Available variables: {title}, {url}, {caption}, {excerpt}
# FACEBOOK_TEMPLATE={title}\n\nRead more: {url}
# INSTAGRAM_TEMPLATE={title}\n\nRead more: Link in bio
# THREADS_TEMPLATE={title}\n\nRead more: {url}
# LINKEDIN_TEMPLATE={title}\n\nRead more: {url}
# X_TEMPLATE={title}\n\n{url}
# TELEGRAM_TEMPLATE=<b>{title}</b>\n\nRead more: {url}
# WHATSAPP_TEMPLATE={title}\n\nRead more: {url}
# PINTEREST_TEMPLATE={title}\n\nRead more: {url}
# YOUTUBE_TEMPLATE={title}\n\nRead more: {url}
